@page
@model TradeControl.Web.Pages.Cash.CategoryTree.TreeDetailsModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    var isEmbedded = string.Equals(Request.Query["embed"], "1", StringComparison.Ordinal);
    if (isEmbedded)
    {
        Layout = null;
    }

    var rootKey = CategoryTreeModel.RootNodeKey;
}

@if (!isEmbedded)
{
    <meta name="request-verification-token" content="@Antiforgery.GetAndStoreTokens(HttpContext).RequestToken" />
    <script src="~/js/categoryTree.shared.js" asp-append-version="true"></script>
    <script>
        if (window.location.hostname === "localhost") {
            window.tcTree = window.tcTree || {};
            window.tcTree.debug = true;
        }
    </script>
}

@if (Model == null || string.IsNullOrWhiteSpace(Model.NodeType))
{
    <div class="text-muted small px-2 py-1">No selection.</div>
}
else if (Model.NodeType == "cashCodeList" && Model.CashCodes != null)
{
    await Html.RenderPartialAsync("_CashCodeListByPolarity", Model.CashCodes);
}
else if (Model.NodeType == "code" && Model.Code != null)
{
    await Html.RenderPartialAsync("_CashCodeDetailsCard", Model.Code);
}
else if (Model.NodeType == "category" && Model.Category != null)
{
    await Html.RenderPartialAsync("_CategoryDetailsCard", Model.Category);
}
else if (Model.NodeType == "expression" && Model.Expression != null)
{
    await Html.RenderPartialAsync("_ExpressionDetailsCard", Model.Expression);
}
else
{
    <div class="text-muted small px-2 py-1">No details available.</div>
}

@if (!isEmbedded && Model?.NodeType == "cashCodeList")
{
    <script>
        (function ()
        {
            function applyCashCodeFilter()
            {
                try
                {
                    var input = document.getElementById("tcCashCodeListSearch");
                    var list = document.getElementById("tcCashCodeList");
                    if (!input || !list)
                    {
                        return;
                    }

                    var q = String(input.value || "").trim().toLowerCase();
                    var items = list.querySelectorAll("[data-action='selectCashCode'][data-search]");
                    var groups = list.querySelectorAll("details[data-cc-group]");

                    if (!q)
                    {
                        items.forEach(function (el) { el.style.display = ""; });
                        groups.forEach(function (el) { el.open = false; });
                        return;
                    }

                    var hitGroups = new Set();

                    items.forEach(function (el)
                    {
                        var hay = String(el.getAttribute("data-search") || "");
                        var hit = hay.indexOf(q) >= 0;
                        el.style.display = hit ? "" : "none";
                        if (hit)
                        {
                            var det = el.closest("details[data-cc-group]");
                            if (det)
                            {
                                hitGroups.add(det);
                            }
                        }
                    });

                    groups.forEach(function (det)
                    {
                        det.open = hitGroups.has(det);
                    });
                }
                catch (_)
                {
                }
            }

            document.addEventListener("click", function (e)
            {
                var box = e.target.closest("[data-action='selectCashCode'][data-cashcode]");
                if (!box)
                {
                    return;
                }

                e.preventDefault();
                e.stopPropagation();

                var cashCode = String(box.getAttribute("data-cashcode") || "").trim();
                if (!cashCode)
                {
                    return;
                }

                // Navigate back to the tree and request selection under ROOT (mobile selector helper expects expand)
                window.location.href =
                    "/Cash/CategoryTree/Index?select="
                    + encodeURIComponent("code:" + cashCode)
                    + "&expand="
                    + encodeURIComponent("@rootKey");
            }, { passive: false });

            document.addEventListener("input", function (e)
            {
                if (e.target && e.target.id === "tcCashCodeListSearch")
                {
                    applyCashCodeFilter();
                }
            }, { passive: true });

            document.addEventListener("keyup", function (e)
            {
                if (e.target && e.target.id === "tcCashCodeListSearch")
                {
                    applyCashCodeFilter();
                }
            }, { passive: true });

            document.addEventListener("change", function (e)
            {
                if (e.target && e.target.id === "tcCashCodeListSearch")
                {
                    applyCashCodeFilter();
                }
            }, { passive: true });
        })();
    </script>
}
