@page
@inject Wangkanai.Detection.Services.IDetectionService Detection
@using Wangkanai.Detection.Models
@model TradeControl.Web.Pages.Subject.Type.DeleteModel

@{
    ViewData["Title"] = "Delete Subject Type";

    var embedded = (Request.Query.TryGetValue("embedded", out var emb) && emb == "1");
    var returnNode = Request.Query.TryGetValue("returnNode", out var rn) ? rn.ToString() : "SubjectType";

    if (embedded)
    {
        Layout = "/Pages/Shared/_EmbeddedLayout.cshtml";
    }

    var backToManagerUrl = $"/Admin/Manager/Index?node={Uri.EscapeDataString(returnNode)}";
}

@if (!embedded)
{
    <h1 class="h4 mb-2 mt-2">@ViewData["Title"]</h1>
}
else
{
    <div class="fw-semibold mb-2">@ViewData["Title"]</div>
}

<div class="bg-white border rounded p-3">
    @if (!embedded && Detection?.Device?.Type == Device.Mobile)
    {
        <div class="d-flex flex-wrap gap-2 mb-3">
            <a href="@backToManagerUrl" class="btn btn-outline-secondary" style="min-width: 7.5rem;">Back</a>
        </div>
    }

    <div class="alert alert-warning border" role="alert">
        This will delete the subject type if it is not referenced by any accounts.
    </div>

    <dl class="row mb-3">
        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Subject_Type.SubjectType)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Subject_Type.SubjectType)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Subject_Type.CashPolarity)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Subject_Type.CashPolarity)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.NumberOfAccounts)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.NumberOfAccounts)</dd>
    </dl>

    <form method="post" class="d-flex flex-wrap gap-2">
        <input type="hidden" asp-for="@Model.Subject_Type.SubjectTypeCode" />

        @if (embedded)
        {
            <input type="hidden" name="embedded" value="1" />
            <input type="hidden" name="returnNode" value="@returnNode" />
        }

        @if (Model.NumberOfAccounts == 0)
        {
            <button type="submit" class="btn btn-danger">Delete</button>
        }

        <a asp-page="./Index"
           asp-route-embedded="@(embedded ? "1" : null)"
           asp-route-returnNode="@returnNode"
           class="btn btn-outline-secondary">
            Cancel
        </a>
    </form>
</div>
