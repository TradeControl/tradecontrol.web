@page
@inject Wangkanai.Detection.Services.IDetectionService Detection
@using Wangkanai.Detection.Models
@model TradeControl.Web.Pages.Subject.Type.IndexModel

@{
    ViewData["Title"] = "Subject Types";

    var embedded = (Request.Query.TryGetValue("embedded", out var emb) && emb == "1");
    var returnNode = Request.Query.TryGetValue("returnNode", out var rn) ? rn.ToString() : "SubjectType";

    if (embedded)
    {
        Layout = "/Pages/Shared/_EmbeddedLayout.cshtml";
    }

    var backToManagerUrl = $"/Admin/Manager/Index?node={Uri.EscapeDataString(returnNode)}";
}

@if (!embedded)
{
    <h1 class="h4 mb-2 mt-2">@ViewData["Title"]</h1>
}
else
{
    <div class="fw-semibold mb-2">@ViewData["Title"]</div>
}

<div class="bg-white border rounded p-3">
    @if (!embedded && Detection?.Device?.Type == Device.Mobile)
    {
        <div class="d-flex flex-wrap gap-2 mb-3">
            <a href="@backToManagerUrl" class="btn btn-outline-secondary" style="min-width: 7.5rem;">Back</a>
        </div>
    }

    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
        <div class="text-muted small">
            Classify organizations by cash polarity (e.g., customers vs suppliers). You can define any set of types that fits the business.
        </div>

        @if (User.IsInRole(Constants.AdministratorsRole))
        {
            <a asp-page="./Create"
               asp-route-embedded="@(embedded ? "1" : null)"
               asp-route-returnNode="@returnNode"
               class="btn btn-outline-primary">
                New Type
            </a>
        }
    </div>

    @if (Model.Subject_Types == null || Model.Subject_Types.Count == 0)
    {
        <div class="alert alert-light border mb-0" role="status">
            No subject types found.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th>@Html.DisplayNameFor(model => model.Subject_Types[0].SubjectType)</th>
                        @if (Detection?.Device?.Type != Device.Mobile)
                        {
                            <th>@Html.DisplayNameFor(model => model.Subject_Types[0].CashPolarity)</th>
                        }
                        <th style="width:1%; white-space:nowrap;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Subject_Types)
                    {
                        <tr>
                            <td class="fw-semibold">@Html.DisplayFor(modelItem => item.SubjectType)</td>

                            @if (Detection?.Device?.Type != Device.Mobile)
                            {
                                <td class="text-muted">@Html.DisplayFor(modelItem => item.CashPolarity)</td>
                            }

                            <td>
                                @if (User.IsInRole(Constants.AdministratorsRole))
                                {
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a class="btn btn-outline-secondary"
                                           asp-page="./Edit"
                                           asp-route-SubjectTypeCode="@item.SubjectTypeCode"
                                           asp-route-embedded="@(embedded ? "1" : null)"
                                           asp-route-returnNode="@returnNode"
                                           title="Edit">
                                            <i class="bi bi-pencil" aria-hidden="true"></i>
                                        </a>
                                        <a class="btn btn-outline-danger"
                                           asp-page="./Delete"
                                           asp-route-SubjectTypeCode="@item.SubjectTypeCode"
                                           asp-route-embedded="@(embedded ? "1" : null)"
                                           asp-route-returnNode="@returnNode"
                                           title="Delete">
                                            <i class="bi bi-trash" aria-hidden="true"></i>
                                        </a>
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
